# Supabase - obter em: supabase.com > Settings > API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Supabase Personal Access Token (sbp_...) - obter em: supabase.com > Account > Access Tokens
# Usado APENAS pelos scripts manuais de migracao/debug em scripts/ (Management API).
# NUNCA vai pro bundle do app nem pras edge functions. Deixe VAZIO no repositorio.
SUPABASE_PAT=

# Gemini AI (legado) - obter em: aistudio.google.com > API Keys
GEMINI_API_KEY=sua-gemini-api-key-aqui

# -----------------------------------------------------------
# ATENÇÃO: NÃO colocar ANTHROPIC_API_KEY aqui.
# A análise de calls (Claude) roda SERVER-SIDE na Edge Function
# `analyze-call`. Configure ANTHROPIC_API_KEY em:
#   Supabase Dashboard > Edge Functions > Secrets
# Se cair no .env do cliente vira string literal no bundle JS.
# -----------------------------------------------------------
